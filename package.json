  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
